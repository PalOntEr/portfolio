---
import Layout from "../layouts/Layout.astro";
import AchievementCard from "../components/AchievementCard.astro";
import { Code2, Layers } from "lucide-astro";


const achievements = [
    {
        name: "NASA International Space Apps Challenge 2025 - Luxe",
        imgsrc: "/portfolio/projects/Luxe.jpg",
        description:
            "First place and global nominee in the NASA International Space Apps Challenge 2025 with 'Luxe', an AI-powered data analysis tool that predicted the possibility of celestial bodies being exoplanets based on data provided byNASA.",
        link: "https://www.linkedin.com/feed/update/urn:li:activity:7383516554531074048/",
        stack: ["Python", "Flask", "Pandas"],
        types: ["Won Hackathon"],
    },
    {
        name: "Swift Changemakers Hackathon 2025 - Liverpool Challenge",
        imgsrc: "/portfolio/projects/Liverpool.jpg",
        description:
            "First place in the Liverpool Challenge of the Swift Changemakers Hackathon 2025 with a solution that helped vendors and customers of Liverpool by providing a mobile application for vendors that combined the online shopping experience and local services.",
        link: "https://www.linkedin.com/feed/update/urn:li:activity:7330432103630725120/",
        stack: ["Swift", "Firebase"],
        types: ["Won Hackathon"],
    },
    {
        name: "Hack Nation's AI Hackathon 2026 - Unmapped by TrePalDo",
        imgsrc: "/portfolio/projects/Unmapped.png",
        description:
            "Participant in the World Bank Youth Summit 2026 with 'Unmapped by TrePalDo', an AI-powered infrastructure that maps real-world skills to jobs and opportunities. Configurable by country, enabling governments and organizations to connect youth with economic pathways using local data.",
        link: "https://projects.hack-nation.ai/#/project/1476d12d-35aa-4e47-8241-714a5e140542",
        stack: ["Python", "FastAPI", "Pandas", "SciKit-Learn"],
        types: ["Participated Hackathon"],
    },
];

const allTypes = [...new Set(achievements.flatMap((p) => p.types))].sort();
const allTechs = [...new Set(achievements.flatMap((p) => p.stack))].sort();

const achievementsByType = allTypes.map((type) => ({
    title: type,
    items: achievements.filter((p) => p.types.includes(type)),
}));

const achievementsByTech = allTechs.map((tech) => ({
    title: tech,
    items: achievements.filter((p) => p.stack.includes(tech)),
}));

---

<Layout title="Achievements | PalOntEr Portfolio">
    <section class="flex flex-col px-6 max-w-7xl mx-auto pt-32 pb-20 gap-12">
        <header
            class="flex flex-col md:flex-row justify-between items-end gap-8 animate-reveal"
        >
            <div class="max-w-2xl">
                <h1
                    class="text-5xl md:text-7xl font-black text-white mb-6 uppercase tracking-tighter"
                >
                    My <span class="text-cyber-cyan text-4xl md:text-7xl">
                        Achievements
                    </span>
                </h1>
                <p
                    class="text-gray-400 text-lg border-l-2 border-cyber-cyan pl-6"
                >
                    A showcase of my accomplishments, certifications, and
                    milestones in the tech world.
                </p>
            </div>

            <!-- View Toggle -->
            <div
                class="flex bg-white/5 max-w-full backdrop-blur-md border border-white/10 p-1 rounded-xl self-start md:self-end"
            >
                <button
                    id="toggle-type"
                    class="view-toggle-btn active flex items-center gap-2 px-6 py-2.5 rounded-lg text-xs sm:text-sm font-bold uppercase tracking-widest transition-all"
                >
                    <Layers class="w-4 h-4" /> Category
                </button>
                <button
                    id="toggle-tech"
                    class="view-toggle-btn flex items-center gap-2 px-6 py-2.5 rounded-lg text-xs sm:text-sm font-bold uppercase tracking-widest transition-all"
                >
                    <Code2 class="w-4 h-4" /> Technology
                </button>
            </div>
        </header>

        <!-- View Containers -->
        <div id="view-by-type" class="view-container space-y-24">
            {
                achievementsByType.map((group, groupIdx) => (
                    <div
                        class="animate-reveal"
                        style={`animation-delay: ${groupIdx * 0.1}s`}
                    >
                        <div class="flex items-center gap-4 mb-10">
                            <h2 class="text-3xl font-black text-white uppercase tracking-tighter">
                                {group.title}s
                            </h2>
                            <div class="h-px grow bg-linear-to-r from-cyber-cyan/50 to-transparent" />
                            <span class="text-xs font-mono text-cyber-cyan/60">
                                {group.items.length} Achievement(s)
                            </span>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                            {group.items.map((achievement) => (
                                <AchievementCard {...achievement} />
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>

        <div id="view-by-tech" class="view-container hidden space-y-24">
            {
                achievementsByTech.map((group, groupIdx) => (
                    <div
                        class="animate-reveal"
                        style={`animation-delay: ${groupIdx * 0.05}s`}
                    >
                        <div class="flex items-center gap-4 mb-10">
                            <h2 class="text-3xl font-black text-white uppercase tracking-tighter">
                                {group.title}
                            </h2>
                            <div class="h-px grow bg-linear-to-r from-cyber-teal/50 to-transparent" />
                            <span class="text-xs font-mono text-cyber-teal/60">
                                {group.items.length} Achievement(s)
                            </span>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                            {group.items.map((achievement) => (
                                <AchievementCard {...achievement} />
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>

    </section>

    <style>
        .view-toggle-btn {
            color: rgba(255, 255, 255, 0.4);
        }
        .view-toggle-btn:hover {
            color: white;
        }
        .view-toggle-btn.active {
            background-color: var(--color-cyber-cyan);
            color: black;
            box-shadow: 0 0 20px rgba(0, 248, 248, 0.3);
        }
        #toggle-tech.active {
            background-color: var(--color-cyber-teal);
            box-shadow: 0 0 20px rgba(0, 186, 186, 0.3);
        }
    </style>

    <script>
        function setupProjectToggle() {
            const btnType = document.getElementById("toggle-type");
            const btnTech = document.getElementById("toggle-tech");
            const viewType = document.getElementById("view-by-type");
            const viewTech = document.getElementById("view-by-tech");

            function switchView(target: string) {
                if (target === "type") {
                    btnType?.classList.add("active");
                    btnTech?.classList.remove("active");
                    viewType?.classList.remove("hidden");
                    viewTech?.classList.add("hidden");
                    window.scrollTo({ top: 0, behavior: "smooth" });
                } else {
                    btnTech?.classList.add("active");
                    btnType?.classList.remove("active");
                    viewTech?.classList.remove("hidden");
                    viewType?.classList.add("hidden");
                    window.scrollTo({ top: 0, behavior: "smooth" });
                }
            }

            btnType?.addEventListener("click", () => switchView("type"));
            btnTech?.addEventListener("click", () => switchView("tech"));
        }

        document.addEventListener("astro:page-load", setupProjectToggle);
    </script>
</Layout>
