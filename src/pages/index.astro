---
import ProjectCard from "../components/ProjectCard.astro";
import StackCard from "../components/StackCard.astro";
import Layout from "../layouts/Layout.astro";
import { ArrowDown, ArrowRight } from "lucide-astro";
---

<Layout title="PalOntEr Main page">
	<!-- Hero Section -->
	<section
		class="relative flex flex-col items-center justify-center px-6 py-20 md:py-24 text-center"
	>
		<!-- Landing Screen -->
		<div
			class="relative flex flex-col items-center justify-center h-[calc(100vh-5rem)] min-h-fit text-center"
		>
			<h1
				class="text-6xl md:text-8xl font-black tracking-tighter text-white mb-6 animate-reveal"
				style="animation-delay: 0.1s"
			>
				SCALABLE <span class="text-cyber-cyan">SOLUTIONS</span><br />
				EXPERTLY <span
					class="text-transparent bg-clip-text bg-linear-to-r from-cyber-cyan to-cyber-teal"
					>CRAFTED</span
				>
			</h1>

			<p
				class="text-lg md:text-xl text-gray-400 max-w-2xl mb-12 leading-relaxed animate-reveal"
				style="animation-delay: 0.2s"
			>
				I create digital solutions that blend
				<span class="text-white font-medium">elegant design</span>
				with
				<span class="text-white font-medium">scalable architecture</span
				>
				and uncompromising technical precision.
			</p>

			<div
				class="flex flex-col sm:flex-row gap-6 mb-24 animate-reveal"
				style="animation-delay: 0.3s"
			>
				<a
					href="/projects"
					class="group relative flex items-center justify-center gap-2 px-10 py-4 bg-cyber-cyan text-black font-black rounded-xl hover:bg-white transition-all hover:scale-105 active:scale-95 shadow-[0_0_30px_rgba(0,248,248,0.4)]"
				>
					PROJECTS
					<ArrowRight
						class="w-5 h-5 group-hover:translate-x-1 transition-transform"
					/>
				</a>
				<a
					href="#contact"
					class="flex items-center justify-center px-10 py-4 bg-white/5 text-white font-bold rounded-xl border border-white/10 hover:bg-white/10 transition-all backdrop-blur-xl"
				>
					CONTACT
				</a>
			</div>

			<div>
				<ArrowDown class="w-8 h-8 animate-bounce" />
			</div>
		</div>

		<!-- Tech Decals -->
		<div class="flex justify-center">
			<h1
				class="text-4xl md:text-5xl font-black text-white mb-4 uppercase tracking-tighter animate-reveal"
			>
				TECHNOLOGY STACK
			</h1>
		</div>
		<div
			class="flex flex-col items-center gap-8 p-4 transition-opacity duration-700 animate-reveal"
			style="animation-delay: 0.4s"
		>
			<div class="grid grid-cols-2 md:grid-cols-4 gap-12">
				<StackCard
					name="TypeScript"
					svgIcon={"/stack/typescript-original.svg"}
				/>
				<StackCard
					name="Node.js"
					svgIcon={"/stack/nodejs-original.svg"}
				/>
				<StackCard name="Astro" svgIcon={"/stack/astro-original.svg"} />
				<StackCard
					name="TailwindCSS"
					svgIcon={"/stack/tailwindcss-original.svg"}
				/>
				<StackCard
					name="Python"
					svgIcon={"/stack/python-original.svg"}
				/>
				<StackCard
					name="AWS"
					svgIcon={"/stack/amazonwebservices-original-wordmark.svg"}
				/>
				<StackCard name="Docker" svgIcon={"/stack/docker-plain.svg"} />
				<StackCard
					name="MS SQL"
					svgIcon={"/stack/microsoftsqlserver-original.svg"}
				/>
			</div>
			<a
				href="/stack"
				class="text-cyber-cyan font-bold hover:tracking-wider hover:scale-110 transition-all flex items-center gap-2 uppercase text-sm"
			>
				VIEW MORE
				<ArrowRight class="w-4 h-4" />
			</a>
		</div>
	</section>

	<!-- Projects Grid -->
	<section id="projects" class="max-w-7xl mx-auto px-6 py-32">
		<div
			class="flex flex-col md:flex-row justify-between items-end gap-8 mb-16"
		>
			<div class="animate-reveal">
				<h2
					class="text-4xl md:text-5xl font-black text-white mb-4 uppercase tracking-tighter"
				>
					Project Showcase
				</h2>
				<p
					class="text-gray-500 max-w-md border-l-2 border-cyber-cyan pl-4"
				>
					A collection of some of my best projects.
				</p>
			</div>
			<a
				href="/projects"
				class="text-cyber-cyan font-bold hover:tracking-wider hover:scale-110 transition-all flex items-center gap-2 uppercase text-sm"
			>
				View More <ArrowRight class="w-4 h-4" />
			</a>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-10">
			<ProjectCard
				name="Colegio San Pedro de Idiomas"
				imgsrc="/projects/CSI.png"
				description="Web page for Colegio San Pedro de Idiomas, an English language school. Hosted in Google Cloud."
				link="https://csimx.org/"
				stack={[
					"Astro",
					"TypeScript",
					"TailwindCSS",
					"Google Cloud Run",
					"Firebase",
				]}
			/>
			<ProjectCard
				name="PhotoHub"
				imgsrc="/projects/PhotoHub.png"
				description="A desktop app that facilitates the application of image, video and camera filters using the CUDA cores of an NVIDIA graphics card"
				link="https://github.com/PalOntEr/PhotoHub"
				stack={["C#", "C++", "CUDA"]}
			/>
			<ProjectCard
				name="Medical 365"
				imgsrc="/projects/Medical365.png"
				description="Health incident and employee status management system that helps manage health reports, track employee status, and generate reports."
				link="https://github.com/oscarvasquez28/Medical-365"
				stack={["React", "Node.js", "MongoDB"]}
			/>
			<ProjectCard
				name="Derby Drift"
				imgsrc="/projects/DerbyDrift.png"
				description="Online multiplayer web game that features two exciting gamemodes that promise fun and competitive play."
				link="https://github.com/oscarvasquez28/Derby-Drift"
				stack={["TypeScript", "Node.js", "Three.js", "TailwindCSS"]}
			/>
		</div>
	</section>
</Layout>
