---
import ProjectCard from "../components/ProjectCard.astro";
import StackCard from "../components/StackCard.astro";
import Layout from "../layouts/Layout.astro";
import { ArrowDown, ArrowRight } from "lucide-astro";
import Prism from "../components/PrismBack.tsx";
import SplitText from "../components/SplitText.tsx";

import { projectsData } from "../data/projects";

const featuredProjects = projectsData.filter(p => 
	["Colegio San Pedro de Idiomas", "PhotoHub", "Medical 365", "Derby Drift"].includes(p.name)
);
---

<Layout title="PalOntEr Main page">
	<!-- Hero Section -->
	<section
		class="relative flex flex-col items-center justify-center h-min-fit px-6 py-20 md:pb-0 md:pt-24 text-center"
	>
		<!-- Background Prism -->
		<div
			class="hidden sm:block absolute inset-0 -top-80 -z-10 opacity-40 pointer-events-none select-none"
		>
			<Prism
				client:only="react"
				timeScale={0.3}
				scale={1.2}
				height={5}
				baseWidth={7}
				noise={0.2}
				hueShift={0}
				colorFrequency={0.25}
				glow={1}
			/>
		</div>

		<!-- Landing Screen -->
		<div
			class="relative flex flex-col items-center justify-center sm:h-[calc(100vh-5rem)] min-h-fit text-center mt-20 sm:mt-0"
		>
			<h1
				class="text-6xl md:text-8xl font-black tracking-tighter text-white mb-6 uppercase"
			>
				<div>
					<SplitText 
						client:only="react"
						text="SCALABLE" 
						delay={25}
					/>
					<SplitText 
						client:only="react"
						text="SOLUTIONS"
						className="text-cyber-cyan"
						delay={25}
						from={{ opacity: 0, y: 40, delay: 0.225 }} 
					/>					
				</div>
				<div class="">
					<SplitText 
						client:only="react"
						text="EXPERTLY" 
						delay={25}
						from={{ opacity: 0, y: 40, delay: 0.45 }}
					/>
					<SplitText 
						client:only="react"
						text="CRAFTED"
						className="text-cyber-cyan"
						delay={25}
						from={{ opacity: 0, y: 40, delay: 0.675 }} 
					/>
				</div>
			</h1>

			<p
				class="text-lg md:text-xl text-gray-400 max-w-2xl mb-12 leading-relaxed animate-reveal"
				style="animation-delay: 0.2s"
			>
				I create digital solutions that blend
				<span class="text-white font-medium">elegant design</span>
				with
				<span class="text-white font-medium">scalable architecture</span
				>
				and uncompromising technical precision.
			</p>

			<div
				class="flex flex-col sm:flex-row gap-6 mb-24 animate-reveal"
				style="animation-delay: 0.3s"
			>
				<a
					href="/portfolio/projects"
					class="group relative flex items-center justify-center gap-2 px-10 py-4 bg-cyber-cyan text-black font-black rounded-xl hover:bg-white transition-all hover:scale-105 active:scale-95 shadow-[0_0_30px_rgba(0,248,248,0.4)]"
				>
					PROJECTS
					<ArrowRight
						class="w-5 h-5 group-hover:translate-x-1 transition-transform"
					/>
				</a>
			</div>

			<div>
				<ArrowDown class="w-8 h-8 animate-bounce" />
			</div>
		</div>
	</section>

	<!-- Projects Grid -->
	<section id="projects" class="max-w-7xl mx-auto px-6 py-20 md:pt-0 md:pb-24">
		<div
			class="flex flex-col md:flex-row justify-between md:items-end gap-8 mb-16"
		>
			<div class="animate-reveal">
				<h2
					class="text-4xl md:text-5xl font-black text-white mb-4 uppercase tracking-tighter"
				>
					Project Showcase
				</h2>
				<p
					class="text-gray-500 max-w-md border-l-2 border-cyber-cyan pl-4"
				>
					A collection of some of my best projects.
					<br />
					<span class="text-cyber-cyan opacity-80">Press</span> on any <span class="text-cyber-cyan opacity-80">project card</span> to see more <span class="text-cyber-cyan opacity-80">details</span>.
				</p>
			</div>
			<a
				href="/portfolio/projects"
				class="text-cyber-cyan font-bold hover:tracking-wider hover:scale-110 transition-all flex self-start sm:self-end items-center gap-2 uppercase text-sm"
			>
				View More <ArrowRight class="w-4 h-4" />
			</a>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-10">
			{featuredProjects.map((project) => (
				<ProjectCard
					name={project.name}
					imgsrc={project.imgsrc}
					description={project.description}
					link={project.link}
					stack={project.stack}
				/>
			))}
		</div>
	</section>
		
	<!-- Tech Decals -->
	<section class="max-w-7xl mx-auto px-6 py-20 md:pt-0 md:pb-24">
		<div
			class="flex flex-col md:flex-row justify-between md:items-end gap-8 mb-16"
		>
			<div class="animate-reveal">
				<h2
					class="text-4xl md:text-5xl font-black text-white mb-4 uppercase tracking-tighter"
				>
					Stack
				</h2>
				<p
					class="text-gray-500 max-w-md border-l-2 border-cyber-cyan pl-4"
				>
					A snapshot of the technologies I work with.
					<br />
					<span class="text-cyber-cyan opacity-80">Hover </span> over each <span class="text-cyber-cyan opacity-80">item</span> to see a brief <span class="text-cyber-cyan opacity-80">description</span>.
				</p>
			</div>
			<a
				href="/portfolio/stack"
				class="text-cyber-cyan font-bold hover:tracking-wider hover:scale-110 transition-all flex self-start sm:self-end items-center gap-2 uppercase text-sm"
			>
				View More <ArrowRight class="w-4 h-4" />
			</a>
		</div>
		<div
			class="flex flex-col items-center gap-8 p-4 transition-opacity duration-700 animate-reveal"
			style="animation-delay: 0.4s"
		>
			<div class="grid grid-cols-2 md:grid-cols-4 gap-12">
				<a href="/portfolio/stack#frontend-&-styling">
					<StackCard name="TypeScript" id="TypeScript" />
				</a>
				<a href="/portfolio/stack#backend-&-frameworks">
					<StackCard name="Node.js" id="Node.js" />
				</a>
				<a href="/portfolio/stack#backend-&-frameworks">
					<StackCard name="Astro" id="Astro" />
				</a>
				<a href="/portfolio/stack#frontend-&-styling">
					<StackCard name="TailwindCSS" id="TailwindCSS" />
				</a>
				<a href="/portfolio/stack#languages">
					<StackCard name="Python" id="Python" />
				</a>
				<a href="/portfolio/stack#cloud-&-devops">
					<StackCard name="AWS" id="AWS" />
				</a>
				<a href="/portfolio/stack#cloud-&-devops">
					<StackCard name="Docker" id="Docker" />
				</a>
				<a href="/portfolio/stack#databases">
					<StackCard name="MS SQL" id="MS SQL" />
				</a>
			</div>
		</div>
	</section>
</Layout>
