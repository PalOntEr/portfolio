---
import ProjectCard from "../components/ProjectCard.astro";
import TechCard from "../components/TechCard.astro";
import Layout from "../layouts/Layout.astro";
import { ArrowRight, Code2, Rocket, Shield, Terminal } from "lucide-astro";
---

<Layout title="PalOntEr Portfolio">
	<!-- Hero Section -->
	<section
		class="relative flex flex-col items-center justify-center px-6 py-20 md:py-32 text-center"
	>
		<h1
			class="text-6xl md:text-8xl font-black tracking-tighter text-white mb-6 animate-reveal"
			style="animation-delay: 0.1s"
		>
			SCALABLE <span class="text-cyber-cyan">SOLUTIONS</span><br />
			EXPERTLY <span
				class="text-transparent bg-clip-text bg-gradient-to-r from-cyber-cyan to-cyber-teal"
				>CRAFTED</span
			>
		</h1>

		<p
			class="text-lg md:text-xl text-gray-400 max-w-2xl mb-12 leading-relaxed animate-reveal"
			style="animation-delay: 0.3s"
		>
			I create digital solutions that blend
			<span class="text-white font-medium">elegant design</span>
			with
			<span class="text-white font-medium">scalable architecture</span>
			and uncompromising technical precision.
		</p>

		<div
			class="flex flex-col sm:flex-row gap-6 animate-reveal"
			style="animation-delay: 0.4s"
		>
			<a
				href="/projects"
				class="group relative flex items-center justify-center gap-2 px-10 py-4 bg-cyber-cyan text-black font-black rounded-xl hover:bg-white transition-all hover:scale-105 active:scale-95 shadow-[0_0_30px_rgba(0,248,248,0.4)]"
			>
				PROJECTS
				<ArrowRight
					class="w-5 h-5 group-hover:translate-x-1 transition-transform"
				/>
			</a>
			<a
				href="#contact"
				class="flex items-center justify-center px-10 py-4 bg-white/5 text-white font-bold rounded-xl border border-white/10 hover:bg-white/10 transition-all backdrop-blur-xl"
			>
				CONTACT
			</a>
		</div>

		<!-- Tech Decals -->
		<div
			class="mt-24 grid grid-cols-2 md:grid-cols-4 gap-12 opacity-40 hover:opacity-100 transition-opacity duration-700 animate-reveal"
			style="animation-delay: 0.5s"
		>
			<TechCard name="Typescript" icon={Terminal} />
			<TechCard name="Astro" icon={Code2} />
			<TechCard name="Tailwind" icon={Shield} />
			<TechCard name="Next.js" icon={Rocket} />
		</div>
	</section>

	<!-- Projects Grid -->
	<section id="projects" class="max-w-7xl mx-auto px-6 py-32">
		<div
			class="flex flex-col md:flex-row justify-between items-end gap-8 mb-16"
		>
			<div class="animate-reveal">
				<h2
					class="text-4xl md:text-5xl font-black text-white mb-4 uppercase tracking-tighter"
				>
					Project Showcase
				</h2>
				<p
					class="text-gray-500 max-w-md border-l-2 border-cyber-cyan pl-4"
				>
					A collection of some of my best projects.
				</p>
			</div>
			<a
				href="/projects"
				class="text-cyber-cyan font-bold hover:tracking-wider hover:scale-110 transition-all flex items-center gap-2 uppercase text-sm"
			>
				View More <ArrowRight class="w-4 h-4" />
			</a>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-10">
			<ProjectCard
				name="Data_Stream_v1.0"
				imgsrc="/projects/data-stream.png"
				position="bottom-left"
			/>
			<ProjectCard
				name="Neural_Interface_v2.4"
				imgsrc="/projects/neural-interface.png"
				position="top-right"
			/>
		</div>
	</section>
</Layout>
