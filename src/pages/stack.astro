---
import StackCard from "../components/StackCard.astro";
import Layout from "../layouts/Layout.astro";

const categories = [
    {
        title: "Languages",
        techs: [
            {
                name: "JavaScript",
                icon: "/portfolio/stack/javascript-original.svg",
            },
            {
                name: "TypeScript",
                icon: "/portfolio/stack/typescript-original.svg",
            },
            { name: "Python", icon: "/portfolio/stack/python-original.svg" },
            { name: "C#", icon: "/portfolio/stack/csharp-original.svg" },
            { name: "C++", icon: "/portfolio/stack/cplusplus-original.svg" },
            { name: "Swift", icon: "/portfolio/stack/swift-original.svg" },
            { name: "HTML5", icon: "/portfolio/stack/html5-original.svg" },
        ],
    },
    {
        title: "Frontend & Styling",
        techs: [
            { name: "React", icon: "/portfolio/stack/react-original.svg" },
            {
                name: "TailwindCSS",
                icon: "/portfolio/stack/tailwindcss-original.svg",
            },
            { name: "Three.js", icon: "/portfolio/stack/threejs-original.svg" },
        ],
    },
    {
        title: "Backend & Frameworks",
        techs: [
            { name: "Astro", icon: "/portfolio/stack/astro-original.svg" },
            { name: "Node.js", icon: "/portfolio/stack/nodejs-original.svg" },
            { name: "Express", icon: "/portfolio/stack/express-original.svg" },
            { name: "FastAPI", icon: "/portfolio/stack/fastapi-original.svg" },
            { name: "Flask", icon: "/portfolio/stack/flask-original.svg" },
            {
                name: "ASP.NET Core",
                icon: "/portfolio/stack/dotnetcore-original.svg",
            },
        ],
    },
    {
        title: "Databases",
        techs: [
            { name: "MongoDB", icon: "/portfolio/stack/mongodb-original.svg" },
            { name: "MySQL", icon: "/portfolio/stack/mysql-original.svg" },
            {
                name: "MS SQL Server",
                icon: "/portfolio/stack/microsoftsqlserver-original.svg",
            },
            { name: "SQLite", icon: "/portfolio/stack/sqlite-original.svg" },
        ],
    },
    {
        title: "Data Science & AI",
        techs: [
            { name: "Pandas", icon: "/portfolio/stack/pandas-original.svg" },
            {
                name: "SciKit-Learn",
                icon: "/portfolio/stack/scikitlearn-original.svg",
            },
        ],
    },
    {
        title: "Cloud & DevOps",
        techs: [
            { name: "Docker", icon: "/portfolio/stack/docker-plain.svg" },
            {
                name: "AWS",
                icon: "/portfolio/stack/amazonwebservices-original-wordmark.svg",
            },
            {
                name: "Google Cloud",
                icon: "/portfolio/stack/googlecloud-original.svg",
            },
            {
                name: "Firebase",
                icon: "/portfolio/stack/firebase-original.svg",
            },
        ],
    },
    {
        title: "Tools & Design",
        techs: [
            { name: "Figma", icon: "/portfolio/stack/figma-original.svg" },
            { name: "Postman", icon: "/portfolio/stack/postman-original.svg" },
            { name: "Swagger", icon: "/portfolio/stack/swagger-original.svg" },
            { name: "NPM", icon: "/portfolio/stack/npm-original.svg" },
        ],
    },
    {
        title: "Version Control Systems",
        techs: [
            { name: "GitHub", icon: "/portfolio/stack/github-original.svg" },
            { name: "Git", icon: "/portfolio/stack/git-original.svg" },
            {
                name: "Bitbucket",
                icon: "/portfolio/stack/bitbucket-original.svg",
            },
            {
                name: "SourceTree",
                icon: "/portfolio/stack/sourcetree-original.svg",
            },
        ],
    },
    {
        title: "Development Environments",
        techs: [
            { name: "VS Code", icon: "/portfolio/stack/vscode-original.svg" },
            {
                name: "Visual Studio",
                icon: "/portfolio/stack/visualstudio-original.svg",
            },
            { name: "Xcode", icon: "/portfolio/stack/xcode-original.svg" },
        ],
    },
    {
        title: "Systems & Engines",
        techs: [
            {
                name: "Unreal Engine",
                icon: "/portfolio/stack/unrealengine-original.svg",
            },
            { name: "Unity", icon: "/portfolio/stack/unity-original.svg" },
            {
                name: "DirectX 11",
                icon: "/portfolio/stack/directx-original.svg",
            },
            { name: "CUDA", icon: "/portfolio/stack/cuda-original.svg" },
            { name: "OpenGL", icon: "/portfolio/stack/opengl-plain.svg" },
            { name: "Linux", icon: "/portfolio/stack/linux-original.svg" },
            { name: "Ubuntu", icon: "/portfolio/stack/ubuntu-original.svg" },
            {
                name: "Windows",
                icon: "/portfolio/stack/windows11-original.svg",
            },
            { name: "Arduino", icon: "/portfolio/stack/arduino-original.svg" },
        ],
    },
];
---

<Layout title="PalOntEr | Technical Stack">
    <section class="max-w-7xl mx-auto px-6 py-24 md:py-32">
        <header class="mb-16 animate-reveal">
            <h1
                class="text-5xl md:text-7xl font-black text-white mb-6 uppercase tracking-tighter"
            >
                Technical <span class="text-cyber-cyan">Stack</span>
            </h1>
            <p
                class="text-gray-400 max-w-2xl text-lg border-l-2 border-cyber-cyan pl-6"
            >
                A comprehensive directory of the technologies, tools, and
                systems I have used throughout my journey.
            </p>
        </header>

        <div class="space-y-20">
            {
                categories.map((category, index) => (
                    <div
                        class="animate-reveal"
                        style={`animation-delay: ${0.1 * (index + 1)}s`}
                    >
                        <h2 class="text-2xl font-bold text-white mb-8 uppercase tracking-widest flex items-center gap-4">
                            <span class="text-cyber-cyan">//</span>{" "}
                            {category.title}
                        </h2>
                        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                            {category.techs.map((tech) => (
                                <StackCard
                                    name={tech.name}
                                    svgIcon={tech.icon}
                                    id={tech.name}
                                />
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>
    </section>
</Layout>
