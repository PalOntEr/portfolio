---
import StackCard from "../components/StackCard.astro";
import Layout from "../layouts/Layout.astro";

const categories = [
    {
        title: "Languages",
        techs: [
            { name: "JavaScript" },
            { name: "TypeScript" },
            { name: "Python" },
            { name: "C#" },
            { name: "C++" },
            { name: "Swift" },
            { name: "HTML5" },
        ],
    },
    {
        title: "Frontend & Styling",
        techs: [
            { name: "React" },
            { name: "TailwindCSS" },
            { name: "Three.js" },
        ],
    },
    {
        title: "Backend & Frameworks",
        techs: [
            { name: "Astro" },
            { name: "Node.js" },
            { name: "Express" },
            { name: "FastAPI" },
            { name: "Flask" },
            { name: "ASP.NET Core" },
        ],
    },
    {
        title: "Databases",
        techs: [
            { name: "MongoDB" },
            { name: "MySQL" },
            { name: "MS SQL Server" },
            { name: "SQLite" },
        ],
    },
    {
        title: "Data Science & AI",
        techs: [{ name: "Pandas" }, { name: "SciKit-Learn" }],
    },
    {
        title: "Cloud & DevOps",
        techs: [
            { name: "Docker" },
            { name: "AWS" },
            { name: "Google Cloud" },
            { name: "Firebase" },
        ],
    },
    {
        title: "Tools & Design",
        techs: [
            { name: "Figma" },
            { name: "Postman" },
            { name: "Swagger" },
            { name: "NPM" },
        ],
    },
    {
        title: "Version Control Systems",
        techs: [
            { name: "GitHub" },
            { name: "Git" },
            { name: "Bitbucket" },
            { name: "SourceTree" },
        ],
    },
    {
        title: "Development Environments",
        techs: [
            { name: "VS Code" },
            { name: "Visual Studio" },
            { name: "Xcode" },
        ],
    },
    {
        title: "Systems & Engines",
        techs: [
            { name: "Unreal Engine" },
            { name: "Unity" },
            { name: "DirectX 11" },
            { name: "CUDA" },
            { name: "OpenGL" },
            { name: "Linux" },
            { name: "Ubuntu" },
            { name: "Windows" },
            { name: "Arduino" },
        ],
    },
];
---

<Layout title="PalOntEr | Technical Stack">
    <section class="max-w-7xl mx-auto px-6 py-24 md:py-32">
        <header class="mb-16 animate-reveal">
            <h1
                class="text-5xl md:text-7xl font-black text-white mb-6 uppercase tracking-tighter"
            >
                Technical <span class="text-cyber-cyan">Stack</span>
            </h1>
            <p
                class="text-gray-400 max-w-2xl text-lg border-l-2 border-cyber-cyan pl-6"
            >
                A comprehensive directory of the technologies, tools, and
                systems I have used throughout my journey.
            </p>
        </header>

        <div class="space-y-20">
            {
                categories.map((category, index) => (
                    <div
                        class="animate-reveal"
                        style={`animation-delay: ${0.1 * (index + 1)}s`}
                    >
                        <h2 class="text-2xl font-bold text-white mb-8 uppercase tracking-widest flex items-center gap-4" id={category.title.toLowerCase().replace(/\s/g, "-")}>
                            <span class="text-cyber-cyan">//</span>{" "}
                            {category.title}
                        </h2>
                        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                            {category.techs.map((tech) => (
                                <StackCard name={tech.name} id={tech.name} />
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>
    </section>
</Layout>
