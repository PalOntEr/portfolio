---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";

interface Props {
    name: string;
    icon: AstroComponentFactory;
}

const { icon: Icon, name } = Astro.props;
---

<div class="flex items-center gap-3 group">
    <div
        class="p-2 bg-cyber-cyan/10 rounded-lg group-hover:bg-cyber-cyan/20 transition-colors"
    >
        <Icon class="w-5 h-5 text-cyber-cyan" />
    </div>
    <span class="text-sm font-bold tracking-widest uppercase">{name}</span>
</div>
