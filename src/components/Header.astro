<header class="fixed top-0 left-0 w-full z-50 px-6 py-4">
  <nav
    class="max-w-7xl mx-auto flex items-center justify-between bg-black/40 backdrop-blur-md border border-cyber-border rounded-2xl px-6 py-3 shadow-[0_0_20px_rgba(0,248,248,0.1)]"
  >
    <a href="/portfolio/" class="flex items-center gap-2">
      <span class="text-xl font-bold tracking-tighter text-white">
        Pal<span class="text-cyber-cyan">Ont</span>Er
      </span>
    </a>

    <div id="desktop-menu" class="hidden md:flex items-center gap-8">
      <a
        href="/portfolio/projects"
        class="text-sm font-medium text-gray-400 hover:text-cyber-cyan hover:scale-110 active:scale-95 transition-all"
        >Projects</a
      >
      <a
        href="/portfolio/achievements"
        class="text-sm font-medium text-gray-400 hover:text-cyber-cyan hover:scale-110 active:scale-95 transition-all"
        >Achievements</a
      >
      <a
        href="/portfolio/stack"
        class="text-sm font-medium text-gray-400 hover:text-cyber-cyan hover:scale-110 active:scale-95 transition-all"
        >Stack</a
      >
      <a
        download="MaxZertuche_Resume.pdf"
        href="/portfolio/files/MaxZertuche_Resume.pdf"
        target="_blank"
        class="px-5 py-2 text-sm font-semibold text-cyber-cyan border border-cyber-cyan/50 rounded-xl hover:bg-cyber-cyan/10 active:scale-95 transition-all"
      >
        Resume
      </a>
    </div>

    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-gray-400 hover:text-cyber-cyan cursor-pointer z-50"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><line x1="4" x2="20" y1="12" y2="12"></line><line
          x1="4"
          x2="20"
          y1="6"
          y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg
      >
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="opacity-0 hidden transition-all duration-250 absolute top-20 left-6 right-6 flex flex-col items-center gap-6 mt-2 bg-black/40 backdrop-blur-lg border border-cyber-border rounded-2xl py-6 shadow-[0_0_20px_rgba(0,248,248,0.1)] md:hidden"
  >
    <a
      href="/portfolio/projects"
      class="text-lg font-medium text-gray-400 hover:text-cyber-cyan transition-all"
      >Projects</a
    >
    <a
      href="/portfolio/achievements"
      class="text-lg font-medium text-gray-400 hover:text-cyber-cyan transition-all"
      >Achievements</a
    >
    <a
      href="/portfolio/stack"
      class="text-lg font-medium text-gray-400 hover:text-cyber-cyan transition-all"
      >Stack</a
    >
    <a
      download="MaxZertuche_Resume.pdf"
      href="/portfolio/files/MaxZertuche_Resume.pdf"
      target="_blank"
      class="px-5 py-2 text-lg font-semibold text-cyber-cyan border border-cyber-cyan/50 rounded-xl hover:bg-cyber-cyan/10 transition-all"
    >
      Resume
    </a>
  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");

    if (btn && menu) {
      // Using onclick ensures we don't accidentally attach multiple listeners across navigations
      btn.onclick = () => {
        menu.classList.toggle("hidden");
        // A tiny timeout ensures the browser registers the removal of 'hidden' before transitioning opacity
        setTimeout(() => {
          menu.classList.toggle("opacity-0");
        }, 10);
      };
    }
  });
</script>
