---
import { Image } from "astro:assets";
import { stackData } from "../data/stack";

interface Props {
    name: string;
    id: string;
    showName?: boolean;
    iconOnly?: boolean;
}

const { name, id, showName = true, iconOnly = false } = Astro.props;
const tech = stackData.find((t) => t.name === name);
const srcAsAny = tech?.imgsrc as any;
---

<div class="relative flex flex-col gap-3 group/stack stack-card">
    <div class="flex items-center gap-3 cursor-pointer">
        <div
            class={!iconOnly ? "p-2 bg-cyber-cyan/10 min-w-fit rounded-lg group-hover/stack:bg-cyber-cyan/20 transition-colors"
                     : ""}
        >
            <Image
                loading="lazy"
                src={srcAsAny}
                alt={name}
                id={id}
                class={!iconOnly ? "w-5 h-5" : "w-fit h-8 lg:h-10 hover:animate-bounce"}
                width={20}
                height={20}
            />
        </div>
        {!iconOnly && showName && (
            <span class="text-sm font-bold tracking-widest uppercase select-none">
            {name}
            </span>
        )}
    </div>
    <span
        class={!iconOnly ? "stack-tooltip absolute top-full left-0 mt-2 z-50 hidden group-hover/stack:block w-max max-w-75 text-xs text-cyber-cyan bg-black/70 backdrop-blur-xl border border-cyber-border rounded-xl p-3 shadow-[0_0_30px_rgba(0,248,248,0.2)] pointer-events-none"
                     : "hidden"}
    >
        {tech?.description}
    </span>
</div>

<script>
    // Close all tooltips when tapping outside
    document.addEventListener("click", () => {
        document.querySelectorAll(".stack-tooltip").forEach((t: any) => {
            t.style.display = "";
        });
    });

    function setupStackPopups() {
        const cards = document.querySelectorAll(".stack-card");
        cards.forEach((card: any) => {
            const tooltip = card.querySelector(".stack-tooltip");
            if (!tooltip) return;

            const adjustPosition = () => {
                const rect = card.getBoundingClientRect();
                // If card is on the right half of the screen, open tooltip extending backward (right-0)
                if (rect.left > window.innerWidth / 2) {
                    tooltip.classList.remove("left-0");
                    tooltip.classList.add("right-0");
                } else {
                    tooltip.classList.remove("right-0");
                    tooltip.classList.add("left-0");
                }
            };

            card.addEventListener("mouseenter", adjustPosition);

            // Toggle on tap/click for mobile
            card.addEventListener("click", (e: Event) => {
                e.stopPropagation(); // Prevent document click from immediately closing it

                // Close others
                document
                    .querySelectorAll(".stack-tooltip")
                    .forEach((t: any) => {
                        if (t !== tooltip) t.style.display = "";
                    });

                // Toggle this one
                if (tooltip.style.display === "block") {
                    tooltip.style.display = "";
                } else {
                    adjustPosition();
                    tooltip.style.display = "block";
                }
            });
        });
    }

    // Initialize logic automatically on load and Astro view transitions
    document.addEventListener("astro:page-load", setupStackPopups);
</script>
