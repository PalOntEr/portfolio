---
import { Image } from "astro:assets";
import StackCard from "./StackCard.astro";
import type { ImageMetadata } from "astro";
import { stackArray, stackEnum } from "../utils/stack";

interface Props {
    name: string;
    imgsrc: string | ImageMetadata;
    link?: string;
    description?: string;
    stack?: string[];
}

const { name, imgsrc, link, description, stack } = Astro.props;
const srcAsAny = imgsrc as any;
---

<div
    class="group/project aspect-video bg-white/5 rounded-2xl border border-white/10 overflow-hidden cursor-pointer animate-reveal"
    style="animation-delay: 0.1s"
>
    <!-- Background Image -->
    <Image
        loading="lazy"
        src={srcAsAny}
        alt={name}
        width={594}
        height={333}
        class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover/project:opacity-70 transition-all duration-700 group-hover/project:scale-110"
    />

    <!-- Hover Gradient Overlay -->
    <a
        href={link}
        target="_blank"
        class="absolute inset-0 bg-linear-to-br from-cyber-cyan/30 via-transparent to-transparent opacity-0 group-hover/project:opacity-100 transition-opacity duration-500"
    >
    </a>

    <!-- Content Overlay -->
    <div class={`w-full flex flex-col h-full p-6`}>
        <a
            href={link}
            target="_blank"
            class="backdrop-blur-md w-fit bg-black/40 border border-white/10 px-4 py-2 rounded-xl shadow-2xl mb-3 text-xs font-bold tracking-[0.3em] uppercase text-gray-200 group-hover/project:text-cyber-cyan transition-colors"
            >{name}</a
        >
        {
            description && (
                <a
                    href={link}
                    target="_blank"
                    class="hidden sm:block text-sm lg:text-base text-gray-300 max-w-3/5 overflow-y-auto group-hover/project:text-cyber-cyan group-hover/project:opacity-70 transition-colors bg-black/40 backdrop-blur-md border border-white/10 px-4 py-2 mb-3 rounded-xl shadow-2xl"
                >
                    {description}
                </a>
            )
        }
        {
            stack && (
                <div
                    class={`flex flex-wrap gap-5 bg-black/40 backdrop-blur-md border w-fit max-w-full border-white/10 px-4 py-2 rounded-xl shadow-2xl`}
                >
                    {stack.map((stack) => (
                        <a
                            href={`/portfolio/stack#${stackArray[stack][stackEnum.Category]}`
                                .toLowerCase()
                                .replace(/\s/g, "-")}
                            class="block text-sm lg:text-base text-gray-300 group-hover/project:text-cyber-cyan transition-colors"
                        >
                            <StackCard name={stack} id={stack} showName={false} iconOnly={true} />
                        </a>
                    ))}
                </div>
            )
        }
    </div>
</div>
