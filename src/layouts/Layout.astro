---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "PalOntEr | Cyber-Minimalist Portfolio",
	description = "A modern, high-performance developer portfolio with a cyber-minimalist design.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/portfolio/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="selection:bg-cyber-cyan/30 selection:text-cyber-cyan">
		<!-- Dynamic Background -->
		<div
			class="fixed inset-0 -z-10 bg-[radial-gradient(circle_at_50%_50%,#001a1a_0%,#000000_100%)]"
		>
		</div>
		<div
			class="fixed inset-0 -z-10 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 brightness-100 contrast-150 pointer-events-none"
		>
		</div>

		<Header />

		<main class="min-h-screen">
			<slot />
		</main>

		<Footer />

		<!-- Global Page Loader -->
		<div
			id="global-loader"
			class="fixed inset-0 z-100 bg-black/60 backdrop-blur-lg flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300"
		>
			<div class="w-16 h-16 border-4 border-white/10 border-t-cyber-cyan border-r-cyber-cyan rounded-full animate-spin shadow-[0_0_15px_rgba(0,248,248,0.5)]"></div>
			<span class="mt-6 text-cyber-cyan text-sm font-bold tracking-[0.3em] uppercase animate-pulse">Loading</span>			
			<span class="mt-2 text-gray-400 text-xs tracking-wide">Please wait while the content loads...</span>
		</div>

		<script>
			// Fired before the new page is fetched
			document.addEventListener("astro:before-preparation", () => {
				document.getElementById("global-loader")?.classList.remove("opacity-0", "pointer-events-none");
			});

			// Fired after the new page is fully loaded and swapped
			document.addEventListener("astro:page-load", () => {
				// Hide the loader 
				document.getElementById("global-loader")?.classList.add("opacity-0", "pointer-events-none");
			});
		</script>
	</body>
</html>
